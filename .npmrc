auto-install-peers=false
strict-peer-dependencies=false

# Use flat node_modules so EAS/Codemagic CI workers can resolve native binaries
# (lightningcss, react-native-* etc.) the same way as plain npm.
node-linker=hoisted

# Force pnpm to hoist babel/expo/metro/@babel/@expo packages so that
# Metro and babel-preset-expo can resolve them from artifacts/mobile/node_modules
# during `expo export:embed` on EAS macOS workers.
public-hoist-pattern[]=*babel*
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*metro*
public-hoist-pattern[]=@babel/*
public-hoist-pattern[]=@expo/*
