{
  "expo": {
    "name": "Asystent Remontu",
    "slug": "asystent-remontu",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "remont",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F97316"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pl.asystentremontu.app",
      "buildNumber": "6",
      "infoPlist": {
        "NSCameraUsageDescription": "Aplikacja potrzebuje dostepu do kamery aby robic zdjecia remontu.",
        "NSPhotoLibraryUsageDescription": "Aplikacja potrzebuje dostepu do galerii aby dodawac zdjecia remontu.",
        "NSLocationWhenInUseUsageDescription": "Aplikacja moze uzyc lokalizacji do wyszukiwania fachowcow w Twojej okolicy.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "pl.asystentremontu.app",
      "versionCode": 6,
      "backgroundColor": "#F97316",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#F97316"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://asystentremontu.pl/",
          "root": "./app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikacja potrzebuje dostepu do galerii aby dodawac zdjecia remontu.",
          "cameraPermission": "Aplikacja potrzebuje dostepu do kamery aby robic zdjecia remontu."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Aplikacja moze uzyc lokalizacji do wyszukiwania fachowcow w Twojej okolicy."
        }
      ],
      [
        "expo-sqlite",
        {}
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "9b70ab60-e7b6-4c8b-8d48-2212d3c166e0"
      }
    },
    "owner": "jakatora12"
  }
}
